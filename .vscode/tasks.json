{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cmake",
			"label": "CMake: build",
			"command": "build",
			"targets": [
				"all"
			],
			"preset": "Debug",
			"group": "build",
			"problemMatcher": [],
			"detail": "CMake template build task"
		},
		{
			"label": "STM32: flash",
			"type": "shell",
			"command": "STM32_Programmer_CLI",
			"args": [
				"-c",
				"port=SWD",
				"mode=UR",
				"reset=HWrst",
				"-w",
				"${workspaceFolder}/build/Debug/Flight.elf",
				"-v",
				"-rst"
			],
			"dependsOn": "CMake: build",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [],
			"detail": "Build and flash Flight.elf with ST-Link"
		}
	]
}
